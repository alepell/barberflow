generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENTE
  ADMIN
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENTE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  agendamentos Agendamento[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model HorarioDisponivel {
  id        String   @id @default(cuid())
  diaSemana Int      // 0=Domingo, 1=Segunda, ..., 6=Sábado
  horaInicio String  // "09:00"
  horaFim    String  // "09:30"
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([diaSemana, horaInicio])
  @@map("horarios_disponiveis")
}

model Agendamento {
  id        String             @id @default(cuid())
  clienteId String
  data      DateTime           @db.Date
  horaInicio String            // "09:00"
  horaFim    String            // "09:30"
  status    StatusAgendamento  @default(PENDENTE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  cliente User @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([data, horaInicio])
  @@map("agendamentos")
}

model BloqueioHorario {
  id     String   @id @default(cuid())
  data   DateTime @db.Date
  horaInicio String
  horaFim    String
  motivo String?
  createdAt DateTime @default(now())

  @@unique([data, horaInicio])
  @@map("bloqueios_horarios")
}
